  );
  
  const commentsSection = adminComments ? 
    buildEmailCard('Admin Comments', adminComments, 'info') : '';
  
  const nextSteps = buildEmailList(getNextSteps(responseType), false);
  
  return standardSendEmail({
    receiver: employeeEmail,
    subject: requestId ? `Leave Request ${requestId} ${responseType}` : `Leave Request ${responseType}`,
