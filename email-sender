/**
 * Build email card component
 * @param {string} title - Card title
 * @param {string} content - Card content (can include HTML)
 * @param {string} style - Card style: 'info', 'success', 'warning', 'danger'
 * @returns {string} HTML card
 */
function buildEmailCard(title, content, style = 'info') {
  const colors = {
    'info': { border: EMAIL_CONFIG.COLORS.INFO, bg: '#e8f4f8' },
    'success': { border: EMAIL_CONFIG.COLORS.SUCCESS, bg: '#e8f6f3' },
    'warning': { border: EMAIL_CONFIG.COLORS.WARNING, bg: '#fef7e8' },
    'danger': { border: EMAIL_CONFIG.COLORS.DANGER, bg: '#fdeaea' }
  };
  
  const color = colors[style] || colors['info'];
  
  return `
    <div style="background: linear-gradient(135deg, ${color.bg}, #ffffff); border: 2px solid ${color.border}; border-radius: 12px; padding: 25px; margin: 25px 0;">
      <h3 style="color: ${EMAIL_CONFIG.COLORS.DARK}; margin: 0 0 15px 0; font-size: 1.1rem;">${title}</h3>
      <div style="color: ${EMAIL_CONFIG.COLORS.DARK}; line-height: 1.6; white-space: pre-line;">${content}</div>
    </div>
  `;
}

/**
 * Build email table component
 * @param {Array} headers - Array of header strings
 * @param {Array} rows - Array of row arrays
 * @param {string} style - Table style: 'bordered', 'striped'
 * @returns {string} HTML table
 */
function buildEmailTable(headers, rows, style = 'bordered') {
  let tableHTML = `
    <table style="width: 100%; border-collapse: collapse; margin: 20px 0; border: 1px solid #e9ecef;">
      <thead>
        <tr style="background: ${EMAIL_CONFIG.COLORS.DARK};">
  `;
  
  // Add headers
  headers.forEach(header => {
    tableHTML += `<th style="padding: 12px; color: white; text-align: left; font-weight: 600; border: 1px solid #e9ecef;">${header}</th>`;
  });
  
  tableHTML += `</tr></thead><tbody>`;
  
  // Add rows
  rows.forEach((row, index) => {
    const bgColor = style === 'striped' && index % 2 === 1 ? '#f8f9fa' : 'white';
    tableHTML += `<tr style="background: ${bgColor};">`;
    
    row.forEach(cell => {
      tableHTML += `<td style="padding: 12px; border: 1px solid #e9ecef; color: ${EMAIL_CONFIG.COLORS.DARK};">${cell}</td>`;
    });
    
    tableHTML += `</tr>`;
  });
  
  tableHTML += `</tbody></table>`;
  
  return tableHTML;
}

/**
 * Build email button component
 * @param {string} text - Button text
 * @param {string} url - Button URL
 * @param {string} style - Button style: 'primary', 'success', 'warning', 'danger'
 * @returns {string} HTML button
 */
function buildEmailButton(text, url, style = 'primary') {
  const colors = {
    'primary': EMAIL_CONFIG.COLORS.PRIMARY,
    'success': EMAIL_CONFIG.COLORS.SUCCESS,
    'warning': EMAIL_CONFIG.COLORS.WARNING,
    'danger': EMAIL_CONFIG.COLORS.DANGER
  };
  
  const color = colors[style] || colors['primary'];
  
  return `
    <div style="text-align: center; margin: 25px 0;">
      <a href="${url}" style="display: inline-block; padding: 14px 32px; background: ${color}; color: white; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 1rem;">${text}</a>
    </div>
  `;
}

/**
 * Build email list component
 * @param {Array} items - Array of list items
 * @param {boolean} ordered - True for numbered list, false for bullet list
 * @returns {string} HTML list
 */
function buildEmailList(items, ordered = false) {
  const tag = ordered ? 'ol' : 'ul';
  let listHTML = `<${tag} style="color: ${EMAIL_CONFIG.COLORS.DARK}; line-height: 1.8; margin: 15px 0; padding-left: 25px;">`;
  
  items.forEach(item => {
    listHTML += `<li style="margin-bottom: 8px;">${item}</li>`;
  });
  
  listHTML += `</${tag}>`;
  
  return listHTML;
}

/**
 * Build email alert component
 * @param {string} message - Alert message
 * @param {string} type - Alert type: 'info', 'success', 'warning', 'danger'
 * @returns {string} HTML alert
 */
function buildEmailAlert(message, type = 'info') {
  const colors = {
    'info': { bg: '#d1ecf1', border: '#bee5eb', text: '#0c5460', icon: 'i' },
    'success': { bg: '#d4edda', border: '#c3e6cb', text: '#155724', icon: '✓' },
    'warning': { bg: '#fff3cd', border: '#ffeaa7', text: '#856404', icon: '!' },
    'danger': { bg: '#f8d7da', border: '#f5c6cb', text: '#721c24', icon: '✗' }
  };
  
  const color = colors[type] || colors['info'];
  
  return `
    <div style="background: ${color.bg}; border: 1px solid ${color.border}; border-left: 4px solid ${color.border}; border-radius: 6px; padding: 15px; margin: 20px 0;">
      <strong style="color: ${color.text};">[${color.icon}] </strong>
      <span style="color: ${color.text}; line-height: 1.6;">${message}</span>
    </div>
  `;
}

/**
 * Build credentials display card
 * @param {Object} credentials - Object with credential fields
 * @returns {string} HTML credentials card
 */
function buildCredentialsCard(credentials) {
  let credentialsHTML = `
    <div style="background: linear-gradient(135deg, #e8f4f8, #ffffff); border: 2px solid ${EMAIL_CONFIG.COLORS.PRIMARY}; border-radius: 12px; padding: 25px; margin: 25px 0;">
      <h3 style="color: ${EMAIL_CONFIG.COLORS.DARK}; margin: 0 0 20px 0;">Login Credentials</h3>
      <div style="display: grid; gap: 15px;">
  `;
  
  for (const [key, value] of Object.entries(credentials)) {
    credentialsHTML += `
      <div style="display: flex; justify-content: space-between; padding: 12px; background: rgba(52, 152, 219, 0.1); border-radius: 6px;">
        <strong style="color: ${EMAIL_CONFIG.COLORS.DARK};">${key}:</strong>
        <span style="color: ${EMAIL_CONFIG.COLORS.PRIMARY}; font-weight: 600;">${value}</span>
      </div>
    `;
  }
  
  credentialsHTML += `</div></div>`;
  
  return credentialsHTML;
}

