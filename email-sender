/**
 * Send emails to multiple admins (for system notifications)
 */
function sendToMultipleAdmins(emailPartsTemplate, adminsList) {
  try {
    const results = {
      success: true,
      sent: 0,
      failed: 0,
      errors: []
    };
    
    for (const admin of adminsList) {
      const emailParts = { ...emailPartsTemplate };
      emailParts.receiver = admin.email;
      
      // Replace admin name placeholder if exists
      if (emailParts.body_greeting) {
        emailParts.body_greeting = emailParts.body_greeting.replace('Administrator', admin.name || 'Administrator');
      }
      
      const result = standardSendEmail(emailParts);
      
      if (result.success) {
        results.sent++;
      } else {
        results.failed++;
        results.errors.push({ email: admin.email, error: result.error });
      }
    }
    
    if (results.failed > 0) {
      results.success = false;
    }
    
    return results;
    
  } catch (error) {
    console.error('Error in sendToMultipleAdmins:', error);
    return {
      success: false,
      error: error.toString()
    };
  }
}

