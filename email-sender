/**
 * Send Unified Leave Response - REPLACES all 3 email functions
 * REPLACE sendLeaveApproved, sendLeaveRejected, and sendLeavePartiallyApproved
 * in email-sender.gs with this single function
 */
function sendLeaveResponse(employeeEmail, employeeName, leaveType, requestId, daysData, adminName, adminComments, actionDate, initialBalanceCurrent, initialBalanceOnHold, initialBalanceNet, finalBalanceCurrent, finalBalanceOnHold, finalBalanceNet) {
  
  // Calculate totals
  const totalDays = daysData.length;
  const approvedCount = daysData.filter(d => d.status === 'Approved').length;
  const pendingCount = daysData.filter(d => d.status === 'Pending').length;
  const rejectedCount = daysData.filter(d => d.status === 'Rejected').length;
  const weeklyHolidayCount = daysData.filter(d => d.isWeeklyHoliday).length;
  const netTotalDays = totalDays - weeklyHolidayCount;
  
  // Calculate net counts
  const approvedNetCount = daysData.filter(d => d.status === 'Approved' && !d.isWeeklyHoliday).length;
  const pendingNetCount = daysData.filter(d => d.status === 'Pending' && !d.isWeeklyHoliday).length;
  const rejectedNetCount = daysData.filter(d => d.status === 'Rejected' && !d.isWeeklyHoliday).length;
  
  // Determine response type and subject
  let responseType, cardColor, cardIcon;
  if (rejectedCount === 0 && pendingCount === 0 && approvedCount === totalDays) {
    responseType = 'Approved';
    cardColor = 'success';
    cardIcon = '✓';
  } else if (approvedCount === 0 && pendingCount === 0 && rejectedCount === totalDays) {
    responseType = 'Rejected';
    cardColor = 'danger';
    cardIcon = '✗';
  } else if (approvedCount > 0) {
    responseType = 'Partially Approved';
    cardColor = 'warning';
    cardIcon = '⚠';
  } else if (rejectedCount > 0 && approvedCount === 0) {
    responseType = 'Partially Rejected';
    cardColor = 'warning';
    cardIcon = '⚠';
  } else {
    responseType = 'Reviewed';
    cardColor = 'info';
    cardIcon = 'ℹ';
  }
  
  const requestIdDisplay = requestId ? `Request ID: ${requestId}` : '';
  
  // Summary section
  const summaryCard = `
    <div style="background: #f8f9fa; border-left: 4px solid #3498db; border-radius: 6px; padding: 15px; margin: 20px 0;">
      <h4 style="margin: 0 0 10px 0; color: #2c3e50;">Response Summary</h4>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;">
        <div style="text-align: center;">
          <div style="font-size: 0.85em; color: #7f8c8d;">Approved</div>
          <div style="font-size: 1.3em; font-weight: bold; color: #27ae60;">${approvedCount} days${approvedNetCount !== approvedCount ? ` (${approvedNetCount} net)` : ''}</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.85em; color: #7f8c8d;">Pending</div>
