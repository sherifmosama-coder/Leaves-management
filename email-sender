/**
 * 6. Send System Reset Notification - FIXED to use string parameters
 * @param {string} resetType - Type of reset: "Immediate" or "Scheduled"
 * @param {string} newStartDate - New start date (YYYY-MM-DD format)
 * @param {string} newEndDate - New end date (YYYY-MM-DD format)
 * @param {string} scheduleDateTime - Schedule datetime for scheduled resets (ISO format) or null
 * @param {string} executedBy - Admin who executed/scheduled the reset
 */
function sendSystemResetNotification(resetType, newStartDate, newEndDate, scheduleDateTime, executedBy) {
  const isScheduled = resetType.toLowerCase().includes('scheduled');
  
  // Build reset info array
  const resetInfo = [
    `Reset Type: ${resetType}`,
    `New Start Date: ${formatDateForDisplay(newStartDate)}`,
    `New End Date: ${formatDateForDisplay(newEndDate)}`
  ];
  
  // Add schedule time or execution time
  if (isScheduled && scheduleDateTime) {
    resetInfo.push(`Scheduled For: ${formatDateTimeForDisplay(scheduleDateTime)}`);
  } else {
    resetInfo.push(`Executed At: ${formatDateTimeForDisplay(new Date())}`);
  }
  
  const resetCard = buildEmailCard(
    'System Reset Details',
    resetInfo.join('\n'),
    'warning'
  );
  
  const importantNote = buildEmailAlert(
    'All employee balances and leave request statuses have been reset to their opening values. This action cannot be undone.',
    'warning'
  );
  
  return standardSendEmail({
    receiver: null, // Will be set by batch sender
    subject: `System Reset ${isScheduled ? 'Scheduled' : 'Executed'}`,
    subtitle: 'System Reset Notification',
    emailType: 'System Reset',
    actualSender: executedBy,
    body_greeting: 'Hello Administrator,',
    body_intro: `The Holiday Management System has been ${isScheduled ? 'scheduled for reset' : 'reset'}.`,
    body_content: resetCard + importantNote,
    body_footer: 'Best regards,\nHoliday Management System',
    logDescription: `System reset notification - ${resetType}`
  });
}

