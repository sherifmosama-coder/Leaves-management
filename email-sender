/**
 * Main standardized email sender function
 * @param {Object} emailParts - Email components
 * @returns {Object} {success: boolean, message: string, error: string}
 */
function standardSendEmail(emailParts) {
  try {
    // Validate required fields
    if (!emailParts || !emailParts.receiver) {
      return { success: false, error: 'Receiver email is required' };
    }
    
    if (!emailParts.body_greeting && !emailParts.body_intro && !emailParts.body_content) {
      return { success: false, error: 'Email body content is required' };
    }
    
    // Get sender email from Config B2
    const configSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Config');
    if (!configSheet) {
      return { success: false, error: 'Config sheet not found' };
    }
    
    const senderEmail = configSheet.getRange('B2').getValue();
    if (!senderEmail) {
      return { success: false, error: 'Sender email not configured in Config B2' };
    }
    
    // Get system URL
    const systemUrl = configSheet.getRange('B1').getValue() || '#';
    
    // Build subject with category prefix if provided
    const subject = emailParts.subject || 'Holiday Management System Notification';
    
    // Build complete HTML email
    const htmlBody = buildCompleteEmailHTML(emailParts, systemUrl);
    
    // Send email using GmailApp
    GmailApp.sendEmail(
      emailParts.receiver,
      subject,
      '', // Empty plain text (HTML only)
      {
        htmlBody: htmlBody,
        from: senderEmail,
        name: 'Holiday Management System'
      }
    );
    
    // Log to email history
    const logResult = saveEmailHistory(
      emailParts.receiver,
      emailParts.emailType || subject,
      emailParts.logDescription || 'Email sent',
      'Sent',
      emailParts.actualSender || 'System'
    );
    
    return {
      success: true,
      message: 'Email sent successfully'
    };
    
  } catch (error) {
    console.error('Error in standardSendEmail:', error);
    
    // Try to log failure
    try {
      saveEmailHistory(
        emailParts.receiver || 'Unknown',
        emailParts.emailType || 'Email Send Failed',
        'Failed to send: ' + error.toString(),
        'Failed',
        emailParts.actualSender || 'System'
      );
    } catch (logError) {
      console.error('Error logging email failure:', logError);
    }
    
    return {
      success: false,
      error: error.toString()
    };
  }
}

