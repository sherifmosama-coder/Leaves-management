function getAdminNameByEmail(email) {
  try {
    if (!email || email === 'System') {
      return 'System';
    }
    
    const adminsSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Admins');
    if (!adminsSheet) {
      console.warn('Admins sheet not found, returning email');
      return email;
    }
    
    const data = adminsSheet.getDataRange().getValues();
    
    // Search for admin by email (Column B)
    for (let i = 1; i < data.length; i++) {
      const rowEmail = data[i][1]; // Column B - Email
      
      if (rowEmail && rowEmail.toString().toLowerCase() === email.toLowerCase()) {
        const adminName = data[i][0]; // Column A - Name
        return adminName || email;
      }
    }
    
    // If not found, return the email
    console.warn('Admin not found for email:', email);
    return email;
    
  } catch (error) {
    console.error('Error getting admin name:', error);
    return email;
  }
}

function getEmployeeNameByEmail(email) {
  try {
    if (!email) {
      return email;
    }
    
    const employeesSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Employees');
    if (!employeesSheet) {
