    if (!adminsSheet) return [];
    
    const data = adminsSheet.getDataRange().getValues();
    const admins = [];
    
    for (let i = 1; i < data.length; i++) {
      const receiveRequests = data[i][4]; // Column E - RECEIVE_REQUESTS
      const status = data[i][8];           // Column I - STATUS
      
      // Check if admin has receive requests enabled AND is active
      if ((receiveRequests === 'Yes' || receiveRequests === true) && 
          status === 'active') {
