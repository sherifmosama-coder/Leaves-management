/**
 * Format array of dates - consecutive as range, scattered with line breaks
 * ADD this helper function to email-sender.gs
 */
function formatDatesArray(datesArray) {
  if (!datesArray || datesArray.length === 0) {
    return 'N/A';
  }
  
  // Convert to Date objects and sort chronologically
  const sortedDates = datesArray
    .map(d => {
      // Handle if already formatted or raw date
      try {
        return new Date(d);
      } catch (e) {
        console.error('Error parsing date:', d);
        return null;
      }
    })
    .filter(d => d !== null && !isNaN(d.getTime()))
    .sort((a, b) => a - b);
  
  if (sortedDates.length === 0) {
    return 'N/A';
  }
  
  // Get weekday abbreviation
  const getWeekday = (date) => {
    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    return days[date.getDay()];
  };
  
  // Format date with weekday
  const formatWithWeekday = (date) => {
    return `${getWeekday(date)}, ${formatDateForDisplay(date)}`;
  };
  
  // Check if all dates are consecutive
  let isConsecutive = true;
  for (let i = 1; i < sortedDates.length; i++) {
    const dayDiff = Math.round((sortedDates[i] - sortedDates[i-1]) / (1000 * 60 * 60 * 24));
    if (dayDiff !== 1) {
      isConsecutive = false;
      break;
    }
  }
  
  if (isConsecutive && sortedDates.length > 1) {
    // Format as range: "Mon, 01/10/2025 to Fri, 05/10/2025"
    return `${formatWithWeekday(sortedDates[0])} to ${formatWithWeekday(sortedDates[sortedDates.length - 1])}`;
  } else if (sortedDates.length === 1) {
    // Single date
    return formatWithWeekday(sortedDates[0]);
  } else {
    // Format with line breaks for scattered dates
    return sortedDates.map(d => formatWithWeekday(d)).join('<br>');
  }
}

/**
 * Format dates with weekly holiday count
 * Returns object with formatted dates and holiday info
 */
function formatDatesWithHolidayInfo(daysArray) {
  if (!daysArray || daysArray.length === 0) {
    return {
      datesFormatted: 'N/A',
      holidayCount: 0,
      netCount: 0
    };
  }
  
  // Extract date strings
  const dateStrings = daysArray.map(d => String(d.date));
  
  // Count weekly holidays
  const holidayCount = daysArray.filter(d => d.isWeeklyHoliday).length;
  const netCount = daysArray.length - holidayCount;
  
  // Format dates
  let datesFormatted = formatDatesArray(dateStrings);
  
  // Add holiday count on new line if any
  if (holidayCount > 0) {
    datesFormatted += `<br><span style="font-size: 0.9em; color: #7f8c8d; font-style: italic;">(${holidayCount} weekly holiday${holidayCount > 1 ? 's' : ''})</span>`;
  }
  
  return {
    datesFormatted: datesFormatted,
    holidayCount: holidayCount,
    netCount: netCount
  };
}
