        <td style="padding: 10px; border: 1px solid #dee2e6; text-align: center; color: #e74c3c; font-weight: bold;">${rejectedMark}</td>
      </tr>
    `;
  });
  
  // Total row
  const totalRow = `
    <tr style="background: #f8f9fa; font-weight: bold; border-top: 2px solid #3498db;">
      <td style="padding: 12px; border: 1px solid #dee2e6;">
        Total: ${totalDays} days
        ${netTotalDays !== totalDays ? `<br><span style="font-size: 0.9em; color: #7f8c8d;">(${netTotalDays} net)</span>` : ''}
      </td>
