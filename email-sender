        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.85em; color: #7f8c8d;">Rejected</div>
          <div style="font-size: 1.3em; font-weight: bold; color: #e74c3c;">${rejectedCount} days${rejectedNetCount !== rejectedCount ? ` (${rejectedNetCount} net)` : ''}</div>
        </div>
      </div>
    </div>
  `;
  
  // Build detailed table rows
  let tableRows = '';
  daysData.forEach(day => {
    const weekdayAbbr = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][new Date(day.date).getDay()];
    const dateFormatted = `${weekdayAbbr}, ${formatDateForDisplay(day.date)}`;
    const holidayMark = day.isWeeklyHoliday ? '✓' : '';
    const approvedMark = day.status === 'Approved' ? '✓' : '';
    const pendingMark = day.status === 'Pending' ? '○' : '';
    const rejectedMark = day.status === 'Rejected' ? '✗' : '';
    
    tableRows += `
      <tr style="border-bottom: 1px solid #ecf0f1;">
        <td style="padding: 10px; border: 1px solid #dee2e6;">${dateFormatted}</td>
