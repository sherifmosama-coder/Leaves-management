}

/**
 * Helper: Get response message based on type
 */
function getResponseMessage(responseType) {
  switch(responseType) {
    case 'Approved':
      return 'Great news! Your leave request has been approved. You can enjoy your time off as planned.';
    case 'Rejected':
      return 'Unfortunately, your leave request could not be approved at this time. Please review the details below.';
    case 'Partially Approved':
      return 'Your leave request has been partially approved. Some dates were approved while others are pending or rejected.';
    case 'Partially Rejected':
      return 'Your leave request has been partially rejected. Some dates are still pending review.';
    default:
      return 'Your leave request has been reviewed. Please see the details below.';
  }
}

/**
 * Helper: Get next steps based on response type
 */
function getNextSteps(responseType) {
  switch(responseType) {
    case 'Approved':
      return [
        'Your approved leave will be automatically deducted from your balance',
        'Ensure all pending tasks are completed before your leave',
        'Set up an out-of-office message if needed',
        'Enjoy your time off!'
      ];
    case 'Rejected':
      return [
        'You may submit a new request for different dates',
        'Contact your administrator to discuss alternatives',
        'Review company leave policies for more information'
      ];
    case 'Partially Approved':
      return [
        'Only approved dates will be deducted from your balance',
        'Pending dates are still under review',
        'You may submit a new request for rejected dates',
        'Contact your administrator if you have questions'
      ];
    case 'Partially Rejected':
      return [
        'Pending dates are still under review',
        'You may submit a new request for rejected dates',
        'Contact your administrator to discuss alternatives'
      ];
    default:
      return [
        'Contact your administrator if you have questions',
        'Review the detailed response above'
      ];
  }
}

