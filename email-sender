    return email;
  }
}

/**
 * Get sender name (checks both Admin and Employee sheets)
 * This is the main function that determines who sent the email
 */
function getSenderName(senderEmailOrName) {
  try {
    // If it's already 'System', return as-is
    if (!senderEmailOrName || senderEmailOrName === 'System') {
      return 'System';
    }
    
    // If it doesn't look like an email, return as-is (already a name)
    if (!senderEmailOrName.includes('@')) {
      return senderEmailOrName;
    }
    
    // It's an email - try to find the name
    // First check Admins sheet
    const adminName = getAdminNameByEmail(senderEmailOrName);
    if (adminName !== senderEmailOrName) {
      // Found in Admins sheet
      return adminName;
    }
    
    // If not found in Admins, check Employees sheet
    const employeeName = getEmployeeNameByEmail(senderEmailOrName);
    if (employeeName !== senderEmailOrName) {
      // Found in Employees sheet
      return employeeName;
    }
    
    // Not found in either sheet, return the email
    return senderEmailOrName;
    
  } catch (error) {
    console.error('Error getting sender name:', error);
    return senderEmailOrName;
  }
}

