/**
 * Format date for display (DD/MM/YYYY)
 */
function formatDateForDisplay(date) {
  if (!date) return 'N/A';
  
  try {
    const d = new Date(date);
    const day = String(d.getDate()).padStart(2, '0');
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const year = d.getFullYear();
    return `${day}/${month}/${year}`;
  } catch (error) {
    return 'Invalid Date';
  }
}

/**
 * Format date and time for display
 */
function formatDateTimeForDisplay(datetime) {
  if (!datetime) return 'N/A';
  
  try {
    const d = new Date(datetime);
    return d.toLocaleString('en-US', { 
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      hour12: true
    });
  } catch (error) {
    return 'Invalid DateTime';
  }
}

/**
 * Save email to history log
 */
function saveEmailHistory(receiverEmail, emailType, description, status, sender) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let emailHistorySheet = ss.getSheetByName('Email history');
    
    // Create sheet if doesn't exist
    if (!emailHistorySheet) {
      emailHistorySheet = ss.insertSheet('Email history');
      const headers = ['Sending date', 'Subject', 'sender', 'Receiver', 'Body (text)', 'Trigger (Auto, action)'];
      emailHistorySheet.getRange(1, 1, 1, headers.length).setValues([headers]);
      
      // Format header
      const headerRange = emailHistorySheet.getRange(1, 1, 1, headers.length);
      headerRange.setBackground('#2c3e50');
      headerRange.setFontColor('#ffffff');
      headerRange.setFontWeight('bold');
    }
    
    // Determine trigger type
    const trigger = sender === 'System' ? 'Auto' : 'Action';
    
    // Add new row
    const newRow = [
      new Date(),
      emailType,
      sender,
      receiverEmail,
      description,
      trigger
    ];
    
    emailHistorySheet.appendRow(newRow);
    
    return { success: true };
    
  } catch (error) {
    console.error('Error logging email to history:', error);
    return { success: false, error: error.toString() };
  }
}

