/**
 * Send Leave Status Notification (determines type and calls appropriate function)
 */
function sendLeaveStatusNotification(statusData) {
  const status = (statusData.status || '').toLowerCase();
  
  // Extract common string parameters
  const employeeEmail = String(statusData.employeeEmail || '');
  const employeeName = String(statusData.employeeName || '');
  const leaveType = String(statusData.leaveType || '');
  const startDate = statusData.startDate ? String(statusData.startDate) : '';
  const endDate = statusData.endDate ? String(statusData.endDate) : '';
  const duration = String(statusData.duration || '0');
  const adminName = String(statusData.adminName || 'Administrator');
  const adminComments = String(statusData.adminComments || '');
  const actionDate = statusData.actionDate ? String(statusData.actionDate) : new Date().toISOString();
  
  if (status.includes('approved') && !status.includes('partial')) {
    // Call sendLeaveApproved with string parameters
    return sendLeaveApproved(
      employeeEmail,
      employeeName,
      leaveType,
      startDate,
      endDate,
      duration,
      adminName,
      adminComments,
      actionDate
    );
  } else if (status.includes('rejected')) {
    // Call sendLeaveRejected with string parameters
    return sendLeaveRejected(
      employeeEmail,
      employeeName,
      leaveType,
      startDate,
      endDate,
      duration,
      adminName,
      adminComments,
      actionDate
    );
  } else if (status.includes('partial')) {
    // Extract additional parameters for partial approval
    const approvedDates = String(statusData.approvedDates || '');
    const rejectedDates = String(statusData.rejectedDates || '');
    const approvedDuration = String(statusData.approvedDuration || '0');
    const rejectedDuration = String(statusData.rejectedDuration || '0');
    
    // Call sendLeavePartiallyApproved with string parameters
    return sendLeavePartiallyApproved(
      employeeEmail,
      employeeName,
      leaveType,
      startDate,
      endDate,
      approvedDates,
      rejectedDates,
      approvedDuration,
      rejectedDuration,
      adminName,
      adminComments,
      actionDate
    );
  }
  
  // Default to approved if status unclear
  return sendLeaveApproved(
    employeeEmail,
    employeeName,
    leaveType,
    startDate,
    endDate,
    duration,
    adminName,
    adminComments,
    actionDate
  );
}

